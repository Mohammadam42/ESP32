void connectToWiFi() {
  if (!WiFi.config(local_IP, gateway, subnet, dns)) {
    Serial.println("❌ Failed to configure static IP");
  }

  WiFi.begin(ssid, password);
  Serial.print("Connecting to WiFi");

  unsigned long startAttemptTime = millis();
  const unsigned long wifiTimeout = 2 * 60 * 1000;  
  while (WiFi.status() != WL_CONNECTED && millis() - startAttemptTime < wifiTimeout) {
    esp_task_wdt_reset();
    delay(500);
    Serial.print(".");
    
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n✅ Connected. IP: ");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("\n⚠️ WiFi connection timeout after 4 minutes. Continuing without WiFi.");
  }
}



// =================== Emergency Button Check Function ===================
bool checkEmergency() {
  if (digitalRead(EMERGENCY_BUTTON) == HIGH || digitalRead(STOP_BUTTON) == HIGH) {
    emergencyState = true;
    if(digitalRead(EMERGENCY_BUTTON) == HIGH){
        stopMotor();
        currentMode = "Stopped";
        sendMessage("EMERGENCY/");
        // Serial.println("EMERGENCY");
    }
    else{
        stopMotor();
        currentMode = "Stopped";
        // Serial.println("Stop");
    }

    return false;
  }
  return true;
}
 
// ===================Button Check Function ===================
void checkButtons() {
  static unsigned long lastDebounceTime = 0;
  const int debounceDelay = 3; 

  // Debounce check
  if (millis() - lastDebounceTime < debounceDelay) {
    return; // wait
  }

  // START_BUTTON (NO, INPUT_PULLDOWN): goes HIGH when pressed
  if (digitalRead(START_BUTTON) == LOW) {
    // Serial.println("START_BUTTON");
    handleCommand("start");
    lastDebounceTime = millis();
    return;
  }

  // STOP_BUTTON (NC, INPUT_PULLUP): goes LOW when pressed
  else if (digitalRead(STOP_BUTTON) == HIGH) {
    // Serial.println("STOP_BUTTON");
    handleCommand("stop");
    lastDebounceTime = millis();
    return;
  }

  // EMERGENCY_BUTTON (NO, INPUT_PULLDOWN): goes HIGH when pressed
  bool currentEmergency = digitalRead(EMERGENCY_BUTTON) == HIGH;
  if (currentEmergency != emergencyState) {
    emergencyState = currentEmergency;
    // Serial.print("EMERGENCY_BUTTON: ");
    // Serial.println(emergencyState ? "PRESSED" : "RELEASED");
    lastDebounceTime = millis();
    return;
  }
}



// =================== Command Handling Function ===================
bool handleCommand(String command) {
  // إذا كان زر الطوارئ مفعل، قم بمنع أي أوامر بدء حركة

  // float voltage = readVoltage();
  float voltage = readVoltage();
  if (voltage > volt) {
    if (command == "start_auto") {
      if (voltage >= 26) {
        stopMotor();
        // startAutoMode();
      } else {
        String message = "1234/" + String(voltage, 3);
        sendMessage(message.c_str());
      }
      return true;
    } 
    else if (command == "start") {
      // Serial.println("start");
      startManualMode();
      return true;
    } 
    else if (command == "stop") {
      stopMotor();
      currentMode = "Stopped";
      // Serial.println("stop");
      sendMessage("7891/");
      return true;
    }
    else if (command == "forward") {
      stopMotor();
      moveUntilLimitSwitch(true); // Move forward
      return true;
    }
    else if (command == "backward") {
      stopMotor();
      moveUntilLimitSwitch(false); // Move backward
      return true;
    }
    else if (command == "status") {
      sendStatus(voltage); // Send status
      return true;
    }
    else if (command == "restart") {
      sendMessage("3343/");
      delay(100);
      sendMessage("Please wait 5 minutes before operating.");
      restartESP();
      return true;
    }
  } 
  else{
    String message = "55556/" + String(voltage, 3);
    sendMessage(message.c_str());
  }
  return false;
}



// =================== Manual Mode Function ===================
void startManualMode() {
  currentMode = "manual";

  if (!checkEmergency()) return;

  sendMessage("🚀Start Save Energy.");
  moveForward();
  startTime = millis() - 90; 
  lastDetectionTime = millis();

  // المرحلة الأولى: التحرك حتى تفعيل LIMIT_SWITCH_1
  while (digitalRead(LIMIT_SWITCH_1) == LOW) {
    if (!checkAllConditions()) return;
    if (isTimeoutExceeded(startTime)) {
      handleTimeout();
      return;
    }
    delay(10);
  }

  // دورة واحدة فقط
  for (int i = 0; i < 1; i++) {
    // التحرك حتى الوصول لأحد Limit Switch
    while ( digitalRead(LIMIT_SWITCH_2) == HIGH) {
      if (!checkAllConditions()) return;
      if (isTimeoutExceeded(startTime)) {
        handleTimeout();
        return;
      }
      delay(10);
    }

if (digitalRead(LIMIT_SWITCH_2) == LOW) {
      stopMotor();
      moveBackward();
      startTime = millis() - 90;
      lastDetectionTime = millis();
    }
    startTime = millis() - 90;
    // LIMIT_SWITCH_2
    while (digitalRead(LIMIT_SWITCH_2) == LOW) {
      if (!checkAllConditions()) return;
      if (isTimeoutExceeded(startTime)) {
        handleTimeout();
        return;
      }
      delay(10);
    }

    totalCycles++;
    startTime = millis() - 90;
  }

  // العودة حتى تفعيل LIMIT_SWITCH_1
  while (digitalRead(LIMIT_SWITCH_1) == HIGH) {
    if (!checkAllConditions()) return;
    if (isTimeoutExceeded(startTime)) {
      handleTimeout();
      return;
    }
    delay(10);
  }

  stopMotor();
  currentMode = "Stopped";
  totalCycles++;
  sendMessage("1234567/");
}

// =================== Move Until a Limit Switch is Triggered ===================
void moveUntilLimitSwitch(bool isForward) {
  currentMode = "Just move";
  startTime = millis();
  lastDetectionTime = millis();

  if (isForward) {
    moveForward();
      while (digitalRead(LIMIT_SWITCH_1) == LOW) {
    if (!checkAllConditions()) return;
    if (isTimeoutExceeded(startTime)) {
      handleTimeout();
      return;
    }
    delay(10);
  }
    
  } else {
    moveBackward();
      while (digitalRead(LIMIT_SWITCH_2) == LOW) {
    if (!checkAllConditions()) return;
    if (isTimeoutExceeded(startTime)) {
      handleTimeout();
      return;
    }
    delay(10);
  }
  }


  while (digitalRead(LIMIT_SWITCH_1) == HIGH && digitalRead(LIMIT_SWITCH_2) == HIGH) {
    if (!checkAllConditions()) {
      stopMotor();
      return;
    }

    if (isTimeoutExceeded(startTime)) {
      handleTimeout();
      return;
    }

    delay(10);
  }

  stopMotor();
  lastDetectionTime = millis();

  if (digitalRead(LIMIT_SWITCH_1) == LOW) {
    sendMessage("12/At charging point");
  } else if (digitalRead(LIMIT_SWITCH_2) == LOW) {
    sendMessage("12/Not at charging point");
  }

  currentMode = "Stopped";
  totalCycles++;
  startTime = millis();
}


// =================== Emergency Movement Until a Limit Switch is Triggered ===================
void moveUntilLimitSwitchsafe(bool isForward, bool first_time = true, int attempt = 0) {
  const int maxAttempts = 1;
  currentMode = "Emergency return";
  lastDetectionTime = millis();
  
  if (isForward) {
    moveForward();
    while (digitalRead(LIMIT_SWITCH_1) == LOW) {
    esp_task_wdt_reset(); 
    if (!checkEmergency() || !receiveMessage()) {
      stopMotor();
      return;
    }
    if (isTimeoutExceeded(startTime)) {
      handleTimeout();
      return;
    }
    delay(10);
  }
    
  } else {
    moveBackward();
    esp_task_wdt_reset(); 
    while (digitalRead(LIMIT_SWITCH_2) == LOW) {
    esp_task_wdt_reset(); 
    if (!checkEmergency() || !receiveMessage()) {
      stopMotor();
      return;
    }
    if (isTimeoutExceeded(startTime)) {
      handleTimeout();
      return;
    }
    delay(10);
  }
  }

  startTime = millis() - 90;

  while (digitalRead(LIMIT_SWITCH_1) == HIGH && digitalRead(LIMIT_SWITCH_2) == HIGH) {
    esp_task_wdt_reset(); 
    if (!checkEmergency() || !receiveMessage()) {
      stopMotor();
      return;
    }

    if (isTimeoutExceeded2(startTime)) {
      esp_task_wdt_reset(); 
      stopMotor();
      sendMessage("1212/");
      currentMode = "Stopped";
      sendMessage("000/");

      if (attempt >= maxAttempts) {
        esp_task_wdt_reset(); 
        sendMessage("999/");
        currentMode = "Stuck";
        stopMotor();
        return;
      }
      moveUntilLimitSwitchsafe(isForward, false, attempt + 1);
      return;
    }
    delay(10);
  }

  stopMotor();
  lastDetectionTime = millis();

  if (digitalRead(LIMIT_SWITCH_1) == LOW) {
    sendMessage("122/");
  } else if (digitalRead(LIMIT_SWITCH_2) == LOW) {
    sendMessage("12/Not at charging point");
  } else {
    currentMode = "Stuck";
    sendMessage("299/");
  }

  currentMode = "Stopped";
  totalCycles++;
  startTime = millis() - 90;
}


//=================== التحكم في المحرك ====================
void moveForward()  {
  lastDirection = "Forward";
  digitalWrite(F_Motor, LOW);
  digitalWrite(R_Motor, HIGH);
  sendMessage("@1");
}

void moveBackward() {
  lastDirection = "Backward";
  digitalWrite(F_Motor, HIGH);
  digitalWrite(R_Motor, LOW);
  sendMessage("@1");
}

void stopMotor() {
  digitalWrite(F_Motor, HIGH);
  digitalWrite(R_Motor, HIGH);
  delay(100);
}
